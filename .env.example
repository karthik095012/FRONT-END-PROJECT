# InternHub Environment Configuration

# Backend Server
PORT=3001
NODE_ENV=development

# Ollama AI Service
OLLAMA_URL=http://localhost:11434/api
OLLAMA_MODEL=neural-chat

# CORS Settings
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# File Upload
MAX_FILE_SIZE=5242880
MAX_RESUME_SIZE=10485760
